    row.className = 'p-row';
    row.innerHTML = `
      <div class="p-num">${i+1}</div>
      <div><input type="text" id="pn${i}" value="${PNAMES[i]}" ${on?'':'disabled'} style="width:100%"></div>
      <div><select id="pp${i}" ${on?'':'disabled'}>${profileOpts}</select></div>
      <div><select id="pt${i}" ${on?'':'disabled'}>
        <option value="human">Human</option>
        <option value="cpu">CPU</option>
      </select></div>
      <div><select id="pc${i}" ${on?'':'disabled'}>
        ${COLORS.map((c,ci)=>`<option value="${ci}" ${ci===i?'selected':''}>${CNAMES[ci]}</option>`).join('')}
      </select></div>`;
    el.appendChild(row);
  }
}

function startGame() {
  const n = +document.getElementById('nump').value;
  G.maxWeeks = +document.getElementById('glen').value;
  G.tpw = +document.getElementById('tpw').value;
  G.ppw = +document.getElementById('ppw').value;
  G.mandated = +document.getElementById('mpw').value;
  G.week = 0; G.curIdx = 0; G.phase = 'playing'; G.evQueue = [];
  G.players = [];
  for (let i = 0; i < n; i++) {
    const profileId = document.getElementById(`pp${i}`).value;
    const profile = PROFILES.find(p => p.id === profileId) || PROFILES[0];
    G.players.push({
      id:i, name: document.getElementById(`pn${i}`).value || `Player ${i+1}`,
      type: document.getElementById(`pt${i}`).value,
