      rankIdx: 0,
      stats: { teaching:0, research:0, grants:0, outreach:0, pubs:0, stress:10 },
      stressHistory: [10],
      burnouts: 0, weeksPlayed: 0,
      milestones: [], isBurnt: false, burntLeft: 0,
    });
  }
  showScreen('game');
  log('The academic year begins. Remember: slow and steady wins.','i');
  renderAll(); startTurn();
}

/* ════════════════════════════════════════════════════
   SCORE FORMULA
   Score = rankBonus - (meanStress * 1.5) - (burnouts * 15)
   Lower stress = better. This is the whole point.
════════════════════════════════════════════════════ */
function computeScore(p) {
  const mean = p.stressHistory.length
    ? p.stressHistory.reduce((a,b)=>a+b,0) / p.stressHistory.length
    : p.stats.stress;
  const rankBonus = RANKS[p.rankIdx].rankBonus;
  return rankBonus - Math.round(mean * 1.5) - (p.burnouts * 15);
}

function meanStress(p) {
  if (!p.stressHistory.length) return p.stats.stress;
  return Math.round(p.stressHistory.reduce((a,b)=>a+b,0) / p.stressHistory.length);
}

/* ════════════════════════════════════════════════════
   GAME LOOP
════════════════════════════════════════════════════ */
function startTurn() {
  // Advance week counter at start of each round
  if (G.curIdx === 0) {
    G.week++;
    document.getElementById('tbweek').textContent =
      G.maxWeeks > 0 ? `Week ${G.week} / ${G.maxWeeks}` : `Week ${G.week}`;

    // Random event every ~3 weeks
    if (G.week > 1 && Math.random() < 0.32) {
      const ev = EVENTS[Math.floor(Math.random() * EVENTS.length)];
      const tgt = G.players[Math.floor(Math.random() * G.players.length)];
      ev.fn(tgt);
      G.evQueue.push({ icon:ev.icon, title:ev.title, sub:`Affects: ${tgt.name}`, body:ev.sub, btns:[{label:'Noted',cb:null}] });
    }
  }

  const p = cur();
  p.weeksPlayed++;

  // Burnout recovery — show overlay, block all interaction
  if (p.isBurnt) {
    p.burntLeft--;
    p.stressHistory.push(p.stats.stress);
    renderAll();
    if (p.type === 'cpu') {
      // CPU just waits silently
      if (p.burntLeft <= 0) { p.isBurnt = false; log(`${p.name} returns from recovery.`,'i'); }
      else log(`${p.name} (CPU) still recovering (${p.burntLeft}w left).`,'w');
      setTimeout(advance, 600);
    } else {
      // Human: show locked overlay
      renderBanner(p);
      showBurnoutOverlay(p);
    }
    return;
  }

  // Passive rank stress (higher rank = more pressure)
  const rankPressure = [1,2,3,4,5][p.rankIdx] || 1;
  // Assoc II perk: salary buffer eases stress
  const stressRelief = p.rankIdx >= 3 ? -2 : 0;
  p.stats.stress = clamp(p.stats.stress + rankPressure + stressRelief, 0, 110);

  if (p.stats.stress >= 100) { burnout(p); return; }
  if (p.stats.stress >= 80)  log(`⚠ ${p.name}'s stress is critical!`, 'c');

  renderAll(); drainQ();

  if (p.type === 'cpu') {
    renderBanner(p);
    setTimeout(() => cpuTurn(p), 800);
  } else {
    renderBanner(p); renderTasks(p); updateConfirm();
  }
}

function advance() {
  G.selTasks = [];
  G.curIdx = (G.curIdx + 1) % G.players.length;
  if (G.curIdx === 0) {
    // End condition: unlimited mode ends only when someone reaches Full Prof
    if (G.maxWeeks > 0 && G.week >= G.maxWeeks) { endGame(); return; }
    if (G.maxWeeks === 0 && G.players.some(p => p.rankIdx >= RANKS.length-1)) { endGame(); return; }
  }
  hideBurnoutOverlay();
  updateConfirm(); startTurn(); renderAll();
}

function showBurnoutOverlay(p) {
  const ov = document.getElementById('burnout-overlay');
  const weeksLeft = p.burntLeft; // already decremented, so 0 means this is the last week
  document.getElementById('bo-title').textContent =
    weeksLeft <= 0 ? `${p.name} — Final Recovery Week` : `${p.name} — Burned Out`;
  document.getElementById('bo-sub').innerHTML =
    weeksLeft <= 0
      ? `This is your last recovery week.\nStress has eased to ${p.stats.stress}.\nYou will return to work next week.`
      : `${weeksLeft} recovery week${weeksLeft>1?'s':''} remaining.\nAll task cards are unavailable.\nStress: ${p.stats.stress} · Rank retained.`;
  document.getElementById('bo-next-btn').textContent =
    weeksLeft <= 0 ? 'Return to work →' : 'Rest this week →';
  // Grey out confirm and task grid
  document.getElementById('confirm').disabled = true;
  document.getElementById('tgrid').innerHTML =
    `<div style="grid-column:1/-1;font-family:'Lora',serif;font-style:italic;font-size:.78rem;color:var(--ink3);text-align:center;padding:20px 0;">No tasks available during recovery.</div>`;
  ov.classList.add('show');
}

function hideBurnoutOverlay() {
  document.getElementById('burnout-overlay').classList.remove('show');
}

function advanceBurnout() {
  const p = cur();
  hideBurnoutOverlay();
  if (p.burntLeft <= 0) {
    p.isBurnt = false;
    log(`${p.name} returns from burnout recovery.`,'i');
  }
  advance();
}

