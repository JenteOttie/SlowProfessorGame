// Pool of tasks that can be MANDATED by the university
const MANDATED_POOL = [
  'a1','a2','a3','a4',   // admin tasks
  't1','t3',             // teaching duties (lectures + marking)
  's1',                  // BSc supervision
];

/* ════════════════════════════════════════════════════
   TASKS
════════════════════════════════════════════════════ */
function drawTasks(p) {
  const pool = TASKS.filter(t => t.minR <= p.rankIdx);
  const bucket = [];
  pool.forEach(t => { const w = Math.max(1, t.w); for (let i=0;i<w;i++) bucket.push(t); });

  // ── Mandated cards (university requirements) ──────────────────────────
  const mandatedCards = [];
  const mandatedCount = G.mandated;
  if (mandatedCount > 0) {
    const availMandated = TASKS.filter(t => MANDATED_POOL.includes(t.id));
    const shuffled = availMandated.sort(() => Math.random() - 0.5);
    // Pick without duplicates, up to mandatedCount
    const usedIds = new Set();
    for (const t of shuffled) {
      if (mandatedCards.length >= mandatedCount) break;
      if (!usedIds.has(t.id)) { usedIds.add(t.id); mandatedCards.push({...t, mandated:true}); }
    }
  }

  // ── Free-choice cards (excluding already-mandated ids) ────────────────
  const mandatedIds = new Set(mandatedCards.map(t => t.id));
  const freeBucket = bucket.filter(t => !mandatedIds.has(t.id));
  const freeTarget = Math.max(0, G.tpw - mandatedCards.length);
  const drawn = [], seen = new Set(mandatedIds);
  let tries = 0;
  while (drawn.length < freeTarget && tries < freeBucket.length * 3) {
    const t = freeBucket[Math.floor(Math.random()*freeBucket.length)]; tries++;
    if (!seen.has(t.id)) { seen.add(t.id); drawn.push(t); }
  }
  // Always ensure at least one rest card in free choices
  if (!drawn.some(t => t.type==='holiday') && mandatedCards.length < G.tpw) {
    const restCard = TASKS.find(t => t.id==='h2');
    if (drawn.length > 0 && !mandatedIds.has('h2')) drawn[drawn.length-1] = restCard;
  }

  // Mandated cards go first so they render prominently
  return [...mandatedCards, ...drawn];
}

function renderTasks(p) {
  G.curTasks = drawTasks(p);
  G.selTasks = [];

  // Auto-select all mandated cards
  G.curTasks.forEach((t, i) => { if (t.mandated) G.selTasks.push(i); });

  const grid = document.getElementById('tgrid');
  grid.innerHTML = '';
  G.curTasks.forEach((t, i) => {
    const c = document.createElement('div');

    // Profile stress modifier for display
    const profileMod = getProfileStressMod(p, t);
    const displayStress = t.stress + profileMod;
    const s = displayStress;
    const spCls = s < 0 ? 'sp-neg' : s < 10 ? 'sp-lo' : s < 16 ? 'sp-md' : 'sp-hi';
    const stCol = s < 0 ? 'var(--blue2)' : s < 10 ? 'var(--green2)' : s < 16 ? 'var(--amber2)' : 'var(--red2)';
    const stTxt = s < 0 ? `Stress ${s}` : s===0 ? 'No stress' : `+${s} stress`;
    const modNote = profileMod !== 0
      ? `<span style="font-size:.52rem;color:${profileMod<0?'var(--blue2)':'var(--red2)'};">${profileMod<0?profileMod:'+'+profileMod} (${p.profile.icon})</span>`
      : '';

    const effs = Object.entries(t.fx).filter(([,v])=>v!==0).map(([k,v]) => {
      const col = STAT_COLORS[k] || '#888';
      return `<span class="tag" style="background:${col}22;color:${col}">${v>0?'+':''}${v} ${k}</span>`;
    }).join('');

    let cls = `tc`;
    if (t.type==='holiday') cls += ' holi';
    if (t.mandated)         cls += ' mandated';
    if (G.selTasks.includes(i)) cls += ' sel';

    c.className = cls;
    c.id = `tc${i}`;
    c.innerHTML = `
      <div class="tc-type tp-${t.type}">${t.type}${t.mandated?' · <span style="color:var(--red2)">REQUIRED</span>':''}</div>
      <div class="tc-title">${t.title}</div>
      <div class="tc-desc">${t.desc}</div>
      <div class="tc-tags">${effs || '<span style="font-size:.6rem;color:var(--ink3);font-style:italic">No stat gain</span>'}</div>
      <div class="tc-stress-row">
        <div class="stress-pip ${spCls}"></div>
        <div class="tc-stress-txt" style="color:${stCol}">${stTxt} ${modNote}</div>
      </div>
      ${t.mandated ? '<div class="mandated-stamp">📌 COMPULSORY</div>' : '<div class="tc-check">✓</div>'}`;

    if (!t.mandated) {
      c.onclick = () => toggleTask(i, p);
    }
    grid.appendChild(c);
  });

  updateConfirm();
}

// Return the net stress modifier this player's profile applies to a given task
function getProfileStressMod(p, t) {
  const prof = p.profile;
  if (!prof || prof.id === 'generalist') return 0;
  // Task-specific override takes priority
  if (prof.taskMods && t.id in prof.taskMods) return prof.taskMods[t.id];
  // Fall back to type-level modifier
  if (prof.mods && t.type in prof.mods) return prof.mods[t.type];
  return 0;
}

function toggleTask(i, p) {
  const t = G.curTasks[i];
  if (t && t.mandated) return; // mandated cards cannot be deselected
  const card = document.getElementById(`tc${i}`);
  const idx = G.selTasks.indexOf(i);
  let maxP = G.ppw;
  if (p.rankIdx >= 1 && G.week % 5 === 0) maxP++;
  if (idx >= 0) {
    G.selTasks.splice(idx, 1); card.classList.remove('sel');
  } else {
    if (G.selTasks.length >= maxP) {
      // Find oldest non-mandated selection to bump
      const bumpIdx = G.selTasks.findIndex(si => !G.curTasks[si]?.mandated);
      if (bumpIdx >= 0) {
        const old = G.selTasks.splice(bumpIdx, 1)[0];
        document.getElementById(`tc${old}`)?.classList.remove('sel');
      } else return; // all slots occupied by mandated tasks
    }
    G.selTasks.push(i); card.classList.add('sel');
  }
  updateConfirm();
}

function updateConfirm() {
  const btn = document.getElementById('confirm');
  const p = cur();
  if (!p || p.type !== 'human' || p.isBurnt) { btn.disabled = true; return; }
  let maxP = G.ppw;
  if (p.rankIdx >= 1 && G.week % 5 === 0) maxP++;
  const mandatedCount = G.selTasks.filter(i => G.curTasks[i]?.mandated).length;
  const freeCount = G.selTasks.length - mandatedCount;
  const freePicks = maxP - mandatedCount;
  btn.disabled = false;
  if (G.selTasks.length > 0) {
    const parts = [];
    if (mandatedCount > 0) parts.push(`${mandatedCount} required`);
    if (freeCount > 0) parts.push(`${freeCount} chosen`);
    btn.textContent = `Confirm ${parts.join(' + ')} task${G.selTasks.length>1?'s':''} and end week →`;
  } else {
    btn.textContent = `Choose up to ${freePicks} free task${freePicks>1?'s':''} (${mandatedCount} required)`;
    if (mandatedCount === 0) btn.disabled = true;
  }
}

function confirmTurn() {
  const p = cur();
  if (!p || G.selTasks.length === 0) return;
  applyTasks(p, G.selTasks.map(i => G.curTasks[i]));
  if (p.stats.stress >= 100) { burnout(p); return; }
  checkMilestones(p);
  p.stressHistory.push(p.stats.stress);
  renderAll();
  setTimeout(advance, 120);
}

function applyTasks(p, tasks) {
  tasks.forEach(t => {
    const profileMod = getProfileStressMod(p, t);
    const effectiveStress = t.stress + profileMod;

    if (t.special === 'highrisk') {
      if (Math.random() > 0.42) {
        p.stats.research += 10; p.stats.pubs += 6;
        log(`${p.name}: risky experiment WORKED! +10 Research, +6 Pubs`,'g');
      } else {
        p.stats.research = Math.max(0, p.stats.research - 2);
        log(`${p.name}: risky experiment flopped. -2 Research`,'b');
      }
    } else if (t.special === 'committee') {
      log(`${p.name}: survived committee. No stats, just suffering.`);
    } else {
      Object.entries(t.fx).forEach(([k,v]) => {
        if (k in p.stats) p.stats[k] = Math.max(0, (p.stats[k]||0) + v);
      });
    }
    p.stats.stress = clamp(p.stats.stress + effectiveStress, 0, 110);
    const sv = effectiveStress < 0 ? `(stress ${effectiveStress})` : effectiveStress > 0 ? `(+${effectiveStress} stress)` : '';
    const profNote = profileMod !== 0 ? ` [${p.profile.icon}${profileMod>0?'+':''}${profileMod}]` : '';
    const mandNote = t.mandated ? ' 📌' : '';
    log(`${p.name}: ${t.title}${mandNote} ${sv}${profNote}`);
  });
}

/* ════════════════════════════════════════════════════
   CPU AI — prioritises stat gaps + stress management
════════════════════════════════════════════════════ */
function cpuTurn(p) {
  const tasks = drawTasks(p); G.curTasks = tasks;
  const nextId = RANKS[Math.min(p.rankIdx+1, RANKS.length-1)].id;
  const req = PROMO_REQ[nextId] || {};
  let maxP = G.ppw;
  if (p.rankIdx >= 1 && G.week % 5 === 0) maxP++;

  // Mandated tasks are always included automatically
  const mandatedIdxs = tasks.map((t,i) => t.mandated ? i : -1).filter(i => i>=0);
  const freeSlots = maxP - mandatedIdxs.length;

  const freeTasks = tasks.map((t,i) => ({t, i})).filter(({t}) => !t.mandated);
  const scored = freeTasks.map(({t, i}) => {
    const profileMod = getProfileStressMod(p, t);
    const effStress = t.stress + profileMod;
    let score = 0;
    // Rest if stressed — more weight the higher the stress
    if (p.stats.stress > 60 && effStress < 0) score += 40 + (p.stats.stress - 60);
    if (p.stats.stress > 80 && effStress < 0) score += 50;
    // Fill stat gaps towards next promotion
    Object.entries(req).forEach(([k, need]) => {
      const gap = need - (p.stats[k]||0);
      if (gap > 0) score += gap * (t.fx[k]||0) * 2;
    });
    // Prefer tasks the profile enjoys (negative effective stress)
    if (effStress < t.stress) score += 8; // profile bonus
    // Avoid high-stress tasks when stressed
    if (p.stats.stress > 55 && effStress > 14) score -= 20;
    score += Math.random() * 8;
    return { i, score };
  });

  scored.sort((a,b) => b.score - a.score);
  const chosenIdxs = [...mandatedIdxs, ...scored.slice(0, Math.max(0, freeSlots)).map(s => s.i)];
  const chosen = chosenIdxs.map(i => tasks[i]);

  applyTasks(p, chosen);

  if (p.stats.stress >= 100) { burnout(p); return; }

  // CPU auto-promotes when eligible
  if (canPromote(p)) doPromotion(p, true);
  checkMilestones(p);
  p.stressHistory.push(p.stats.stress);
  log(`${p.name} (CPU): ${chosen.map(t=>t.title).join(' + ')}`);
  renderAll();
  setTimeout(advance, 300);
}

/* ════════════════════════════════════════════════════
   PROMOTION
════════════════════════════════════════════════════ */
function canPromote(p) {
  if (p.rankIdx >= RANKS.length-1) return false;
  const nId = RANKS[p.rankIdx+1].id;
  const req = PROMO_REQ[nId]; if (!req) return false;
  return Object.entries(req).every(([k,v]) => (p.stats[k]||0) >= v);
}

function tryPromotion() {
  const p = cur();
  if (!canPromote(p)) {
    openOv({ icon:'📋', title:'Not Eligible Yet',
      sub:`Requirements for ${RANKS[Math.min(p.rankIdx+1,RANKS.length-1)].label}:`,
      body: promoReqText(p),
      btns:[{label:'Back to work',cls:''}]
    }); return;
  }
  doPromotion(p, false);
}

function doPromotion(p, auto) {
  const old = RANKS[p.rankIdx].label;
  p.rankIdx++;
  const nw = RANKS[p.rankIdx];
  p.milestones.push(`Promoted: ${nw.label} (Wk ${G.week})`);
  log(`🎓 ${p.name} promoted to ${nw.label}!`,'g');
  if (!auto) {
    openOv({ icon:'🎓', title:'Promoted!',
      sub:`${p.name} advances to ${nw.label}`,
      body:`Previous rank: ${old}\n\nNote: higher rank means slightly more\npassive stress each week. Manage carefully.\n${p.rankIdx===1?'\nPerk: bonus task pick every 5 weeks.':''}${p.rankIdx===3?'\nPerk: salary buffer eases stress each week.':''}`,
      btns:[{label:'Accept the burden',cls:''}]
    });
  }
  if (G.maxWeeks === 0 && p.rankIdx >= RANKS.length-1) { setTimeout(endGame, 600); }
  renderAll();
}

function promoReqText(p) {
  if (p.rankIdx >= RANKS.length-1) return 'You are at the top rank.';
  const nId = RANKS[p.rankIdx+1].id;
  const req = PROMO_REQ[nId]; if (!req) return 'No requirements defined.';
  return Object.entries(req).map(([k,v]) => {
    const have = p.stats[k]||0;
    return `${(k+'          ').slice(0,10)} ${String(have).padStart(3)} / ${v}  ${have>=v?'✓':'✗'}`;
  }).join('\n');
}

/* ════════════════════════════════════════════════════
   BURNOUT — no rank loss, just recovery time
════════════════════════════════════════════════════ */
function burnout(p) {
  p.stats.stress = 45;
  p.burnouts++;
  p.isBurnt = true; p.burntLeft = 3;
  p.stressHistory.push(100); // punishes mean stress
  p.milestones.push(`Burned out at ${RANKS[p.rankIdx].label} (Wk ${G.week})`);
  log(`🔥 ${p.name} has burned out! 3 weeks recovery. Rank kept.`,'c');
  openOv({ icon:'🔥', title:'Burnout!',
    sub:`${p.name} collapses under academic pressure.`,
    body:`Recovery: 3 weeks mandatory rest\nStress reset to 45\nRank retained: ${RANKS[p.rankIdx].label}\n\nBurnout count: ${p.burnouts}\nEach burnout costs −15 points on your final score.\n\nThis is not failure. But it is a warning.\nAcademia is hard. Take care of yourself.`,
    btns:[{label:'Rest and recover',cls:''}]
  });
  renderAll(); setTimeout(advance, 300);
}

/* ════════════════════════════════════════════════════
   MILESTONES
════════════════════════════════════════════════════ */
function checkMilestones(p) {
  const chks = [
    {k:'pubs',v:10,m:'📄 10 publications!'},{k:'pubs',v:25,m:'📄 25 publications!'},
    {k:'grants',v:20,m:'💰 20 grant points!'},{k:'grants',v:50,m:'💰 50 grant points!'},
    {k:'teaching',v:30,m:'🎓 30 teaching points!'},{k:'outreach',v:25,m:'📢 25 outreach!'},
  ];
  chks.forEach(c => {
    const key = `ms_${c.k}_${c.v}`;
    if ((p.stats[c.k]||0) >= c.v && !p.milestones.includes(key)) {
      p.milestones.push(key); log(`${p.name}: ${c.m}`,'g');
    }
  });
}

/* ════════════════════════════════════════════════════
   END GAME
════════════════════════════════════════════════════ */
function endGame() {
  G.phase = 'end';
  // Final scoring: lowest mean stress wins
  const results = G.players.map(p => ({
    p, score: computeScore(p), mean: meanStress(p),
  }));
  results.sort((a,b) => b.score - a.score); // highest score wins
  const winner = results[0].p;

  showScreen('win');
  const rankCounts = results.map(r=>`<tr class="${r.p===winner?'winner':''}">
    <td>${r.p===winner?'🏆 ':''}<span style="color:${r.p.color};font-weight:bold">${r.p.name}</span></td>
    <td>${RANKS[r.p.rankIdx].short}</td>
    <td>${r.mean}</td>
    <td>${r.p.burnouts}</td>
    <td style="color:${r.p===winner?'var(--green2)':'var(--ink2)'};font-weight:bold">${r.score}</td>
  </tr>`).join('');

  document.getElementById('diploma').innerHTML = `
    <span class="dip-ornament">✦ ✦ ✦</span>
    <div class="dip-univ">THE UNIVERSITY OF SLOW ACADEMIA</div>
    <div class="dip-cert">presents the Award for Academic Wellbeing to</div>
    <div class="dip-winner" style="color:${winner.color}">${winner.name}</div>
    <div class="dip-why">${RANKS[winner.rankIdx].label} · Mean Stress: ${meanStress(winner)}</div>
    <div style="font-family:'Lora',serif;font-style:italic;font-size:.88rem;color:var(--green);margin-bottom:14px;">
      for achieving the highest score through sustainable work practices
    </div>
    <table class="dip-table">
      <thead><tr>
        <th>Name</th><th>Rank</th><th>Mean Stress</th><th>Burnouts</th><th>Score</th>
      </tr></thead>
      <tbody>${rankCounts}</tbody>
    </table>
    <hr class="dip-sep">
    <div style="font-family:'Special Elite',monospace;font-size:.65rem;color:var(--ink3);letter-spacing:.06em;margin-bottom:6px;">
      Score = Rank Bonus − (Mean Stress × 1.5) − (Burnouts × 15)
    </div>
    <span class="dip-ornament">✦ ✦ ✦</span>
    <div class="dip-quote">"The measure of a career is not how high you climbed,<br>but how well you breathed on the way up."</div>`;
}

/* ════════════════════════════════════════════════════
   RENDER
════════════════════════════════════════════════════ */
function renderAll() {
  renderRoster(); renderLadder(); renderLB(); renderScoreboard();
  renderPromoReq(); renderMilestones(); drainQ();
}

function renderRoster() {
  const el = document.getElementById('roster-cards'); el.innerHTML = '';
  G.players.forEach((p, i) => {
    const rank = RANKS[p.rankIdx];
    const isActive = i === G.curIdx;
    const s = p.stats.stress;
    const sc = s<40?'sb-ok':s<70?'sb-warn':s<85?'sb-high':'sb-crit';
    const card = document.createElement('div');
    card.className = `pc${isActive?' active':''}${p.isBurnt?' burnt':''}`;
    const stats = STAT_KEYS.map(k => {
      const v = p.stats[k]||0;
      const pct = Math.min(100, v/70*100);
      return `<div class="srow"><div class="sl">${STAT_LABELS[k]}</div>
        <div class="sb"><div class="sf" style="width:${pct}%;background:${STAT_COLORS[k]}"></div></div>
        <div class="sv">${v}</div></div>`;
    }).join('');
    let badge = '';
    if (isActive && p.type!=='cpu') badge = '<div class="pc-badge pc-badge-turn">YOUR TURN</div>';
    if (p.type==='cpu') badge += `<div class="pc-badge pc-badge-cpu">CPU</div>`;
    if (p.isBurnt) badge = `<div class="pc-badge pc-badge-burnt">RECOVERY (${p.burntLeft}w)</div>`;
    card.innerHTML = `${badge}
      <div class="pc-colbar" style="background:${p.color}"></div>
      <div class="pc-name">${p.name}</div>
      <div class="pc-rank">${rank.short}</div>
      <div class="pc-profile">${p.profile.icon} ${p.profile.label}</div>
      ${stats}
      <div class="srow" style="margin-top:3px">
        <div class="sl">STRESS</div>
        <div class="sb"><div class="sf sf-stress" style="width:${Math.min(100,s)}%"></div></div>
        <div class="sv"><span class="sbadge ${sc}">${s}</span></div>
      </div>
      <div class="pc-pts">Wk avg stress: ${meanStress(p)}</div>
      <div class="pc-score">Score: ${computeScore(p)}</div>`;
    el.appendChild(card);
  });
}

function renderBanner(p) {
  const rank = RANKS[p.rankIdx];
  const s = p.stats.stress;
  const status = s<40?'Feeling refreshed and focused.':s<70?'Managing the workload.':s<85?'⚠ Stress is building — consider a rest.':'🔥 Critical stress! A holiday is not a luxury.';
  const statusCol = s<40?'var(--green2)':s<70?'var(--ink3)':s<85?'var(--amber2)':'var(--red2)';
  let maxP = G.ppw;
  if (p.rankIdx>=1 && G.week%5===0) maxP++;
  const canP = canPromote(p);
  document.getElementById('banner').innerHTML = `
    <div>
      <div class="bn-name" style="color:${p.color}">${p.name}</div>
      <div class="bn-rank">${rank.label}</div>
      <div class="bn-status" style="color:${statusCol}">${status}</div>
    </div>
    <div class="bn-right">
      <div class="bn-wk">Week ${G.week}${G.maxWeeks>0?' / '+G.maxWeeks:''}</div>
      <div class="bn-picks">Pick up to ${maxP} task${maxP>1?'s':''}</div>
      <button class="promo-btn" onclick="tryPromotion()" ${canP?'':'disabled'}>
        ${canP?'📋 Apply for Promotion':'Promotion requirements not met'}
      </button>
    </div>`;
}

function renderLadder() {
  const el = document.getElementById('ladder'); el.innerHTML = '';
  [...RANKS].reverse().forEach(rank => {
    const ps = G.players.filter(p => RANKS[p.rankIdx].id===rank.id);
    const r = document.createElement('div');
    r.className = `l-rung${ps.length?' has':''}`;
    r.innerHTML = `<div class="lr-label">${rank.short}</div>
      <div class="lr-dots">${ps.map(p=>`<div class="lr-dot" style="background:${p.color}" title="${p.name}"></div>`).join('')}</div>`;
    el.appendChild(r);
  });
}

function renderLB() {
  const sorted = [...G.players].sort((a,b) => computeScore(b)-computeScore(a));
  document.getElementById('lb').innerHTML = sorted.map((p,i) => `
    <div class="lb-row">
      <span style="color:var(--cork2);min-width:14px">${i+1}.</span>
      <span style="color:${p.color};font-weight:bold;flex:1">${p.name}</span>
      <span style="color:var(--ink3)">${RANKS[p.rankIdx].short}</span>
      <span style="color:var(--green2);min-width:28px;text-align:right">${computeScore(p)} pts</span>
    </div>`).join('');
}

function renderScoreboard() {
  const el = document.getElementById('scoreboard');
  el.innerHTML = G.players.map(p => {
    const m = meanStress(p);
    const rb = RANKS[p.rankIdx].rankBonus;
    const sc = computeScore(p);
    return `<div class="score-row">
      <span class="score-key" style="color:${p.color}">${p.name}</span>
      <span class="score-val">${sc} <span style="font-size:.56rem;color:var(--ink3)">(rank +${rb}, stress −${Math.round(m*1.5)}, bo −${p.burnouts*15})</span></span>
    </div>`;
  }).join('');
}

function renderPromoReq() {
  const p = cur(); if (!p) return;
  const next = p.rankIdx < RANKS.length-1 ? RANKS[p.rankIdx+1].label : 'Already at top';
  document.getElementById('promo-req').innerHTML = `
    <div style="font-family:'Special Elite',monospace;font-size:.6rem;color:var(--ink3);margin-bottom:4px">
      Next: ${next}</div>
    <div class="promo-req-text">${promoReqText(p)}</div>`;
}

function renderMilestones() {
  const all = G.players.flatMap(p => p.milestones.filter(m=>!m.startsWith('ms_')));
  const el = document.getElementById('milestones');
  el.innerHTML = all.length
    ? all.slice(-8).map(m=>`<div class="ms">🏅 ${m}</div>`).join('')
    : '<div style="font-size:.68rem;color:var(--ink3);font-style:italic">No milestones yet...</div>';
}

/* ════════════════════════════════════════════════════
   OVERLAY SYSTEM
════════════════════════════════════════════════════ */
let ovCbs = [];
function openOv({icon='',title,sub,body,btns}) {
  document.getElementById('ov-icon').textContent = icon;
  document.getElementById('ov-title').textContent = title||'';
  document.getElementById('ov-sub').textContent = sub||'';
  document.getElementById('ov-body').textContent = body||'';
  ovCbs = btns||[];
  const bel = document.getElementById('ov-btns'); bel.innerHTML='';
  (btns||[{label:'Continue',cls:''}]).forEach((b,i) => {
    const btn = document.createElement('button');
    btn.className = `ov-btn${b.cls?' '+b.cls:''}`;
    btn.textContent = b.label;
    btn.onclick = () => { closeOv(); b.cb&&b.cb(); drainQ(); };
    bel.appendChild(btn);
  });
  document.getElementById('ov').classList.add('show');
}
function closeOv() { document.getElementById('ov').classList.remove('show'); }
function drainQ() {
  if (G.evQueue.length && !document.getElementById('ov').classList.contains('show'))
    openOv(G.evQueue.shift());
}

/* ════════════════════════════════════════════════════
   MISC HELPERS
════════════════════════════════════════════════════ */
function cur() { return G.players[G.curIdx]; }
function clamp(v,lo,hi) { return Math.min(hi,Math.max(lo,v)); }
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function backToSetup() { G.phase='setup'; showScreen('setup'); buildSlots(); }

function log(msg, cls='') {
  const el = document.getElementById('log'); if(!el) return;
  const d = document.createElement('div');
  d.className = `le${cls?' '+cls:''}`;
  d.textContent = msg;
  el.appendChild(d);
  el.scrollTop = el.scrollHeight;
  while (el.children.length > 60) el.removeChild(el.firstChild);
}

function openHelp() {
  openOv({ icon:'📖', title:'How to Play',
    sub:'Climb the academic ladder — sustainably.',
    body:`WIN CONDITION: lowest MEAN STRESS score wins.
Score = Rank Bonus − (Mean Stress × 1.5) − (Burnouts × 15)
You can win as an Assistant Professor!

PROFILES:
  Your profile adjusts stress costs on task cards.
  A Field Ecologist finds fieldwork energising (less
  stress), but suffers more in admin roles.
